# Copy to .env and export, or use django-environ / your process manager
DJANGO_SECRET_KEY=change-me
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_ALLOWED_HOSTS=example.com

# Production database
POSTGRES_DB=access_control
POSTGRES_USER=access_control
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Production email (SMTP)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=access-control@yourdomain.com

REDIS_URL=redis://127.0.0.1:6379/1
